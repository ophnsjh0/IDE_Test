# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Environment variables — API keys live here, never commit
.env

# Local SQLite DB — 계정 정보 포함, 커밋 금지 (Postgres 전환 시까지 로컬 전용)
backend/db.sqlite3

# Gmail OAuth secrets — never commit these
backend/credentials.json
backend/token.json
credentials.json
token.json

# Gmail 동기화 동시 실행 방지용 잠금 파일
backend/.gmail_sync.lock

# collectstatic 산출물 (도커 빌드 시 이미지 안에서 생성)
backend/staticfiles/

# 사내 보고서 템플릿 — 실물 템플릿에 내부 정보(로고·결재선)가 들어가므로 커밋 금지
backend/report_templates/
