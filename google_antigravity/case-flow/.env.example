# CaseFlow 환경 변수 견본 — 실제 값을 채워 .env로 저장 (커밋 금지)
# VM 도커 배포 시에는 docker-compose.yml과 같은 디렉터리에 둔다.

# ── AI / 검색 API 키 ─────────────────────────────
CLAUDE_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=

# ── 서비스 설정 ──────────────────────────────────
# 프론트 접속 origin (CSRF/CORS 허용 목록). IP만 쓰면 :3000으로 보정, 대역은 192.168.0.* 형태 가능
CASEFLOW_FRONTEND_ORIGINS=localhost,127.0.0.1
CASEFLOW_SIGNUP_APPROVER_EMAIL=

# ── 운영(VM) 전용 — 로컬 개발에서는 생략하면 기존 개발 동작 유지 ──
# python -c "import secrets; print(secrets.token_urlsafe(50))" 로 생성
DJANGO_SECRET_KEY=
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=<VM_IP>
CASEFLOW_CORS_ALLOW_ALL=0

# PostgreSQL (docker-compose가 db 컨테이너와 backend 양쪽에 주입)
POSTGRES_DB=caseflow
POSTGRES_USER=caseflow
POSTGRES_PASSWORD=
